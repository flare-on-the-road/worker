# ITS CCTV API
ITS_API_KEY=your_its_api_key
ITS_CCTV_API_URL=https://openapi.its.go.kr:9443/cctvInfo

# Cloudflare R2
CF_ACCOUNT_ID=your_cf_account_id
CF_ACCESS_KEY=your_r2_access_key
CF_SECRET_KEY=your_r2_secret_key
CF_BUCKET_NAME=your_bucket_name

# Vision Model FastAPI (VMware Linux VM)
VISION_API_URL=http://192.168.x.x:8000
VISION_TIMEOUT=15

# Flask Backend
BACKEND_API_URL=http://192.168.x.x:5001
BACKEND_TIMEOUT=10
